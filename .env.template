# SE Knowledge Search - Environment Variables
# Copy this to .env and fill in your values

# Slack tokens (extract from browser - see README)
# See: https://github.com/korotovsky/slack-mcp-server
SLACK_MCP_XOXC_TOKEN=xoxc-your-token-here
SLACK_MCP_XOXD_TOKEN=xoxd-your-token-here

# Gong API credentials (Admin → Company Settings → API)
GONG_ACCESS_KEY=your-access-key
GONG_ACCESS_KEY_SECRET=your-secret-key

# Highspot API key (Admin → Integrations → API Keys)
HIGHSPOT_API_KEY=your-api-key
